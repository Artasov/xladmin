{
  "compilerOptions": {
    "target": "ES2019",
    "lib": [
      "dom",
      "esnext"
    ],
    "jsx": "react-jsx",
    "baseUrl": ".",
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@xladmin-core/*": [
        "packages/xladmin-core/src/*"
      ],
      "xladmin": [
        "packages/xladmin-core/src/index.ts"
      ],
      "xladmin-next": [
        "packages/xladmin-next/src/index.tsx"
      ],
      "xladmin-import-export": [
        "packages/xladmin-import-export/src/index.ts"
      ],
      "xladmin-react-router": [
        "packages/xladmin-react-router/src/index.tsx"
      ]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
