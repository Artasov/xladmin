{
  "name": "xladmin-frontend-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/xladmin-core",
    "packages/xladmin-next",
    "packages/xladmin-react-router"
  ],
  "scripts": {
    "build": "npm run build --workspace ./packages/xladmin-core && npm run build --workspace ./packages/xladmin-next && npm run build --workspace ./packages/xladmin-react-router",
    "check": "npm run check --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "pack:dry-run": "cd packages/xladmin-core && npm pack --dry-run && cd ../xladmin-next && npm pack --dry-run && cd ../xladmin-react-router && npm pack --dry-run"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.0.0",
    "@mui/material": "^7.0.0",
    "@mui/x-date-pickers": "^8.27.0",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "axios": "^1.12.2",
    "dayjs": "^1.11.19",
    "jsdom": "^26.1.0",
    "next": "^15.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.6.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "yaml": "^2.8.3"
  }
}
